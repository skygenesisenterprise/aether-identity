{
  "name": "@aether-identity/cli",
  "version": "1.0.0",
  "description": "Aether Identity CLI - DevOps and automation interface for Aether Identity",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "identity": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "cli": "node ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "ora": "^8.1.1",
    "conf": "^12.0.0",
    "dotenv": "^16.4.7",
    "inquirer": "^9.2.28"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "eslint": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "identity",
    "aether",
    "auth",
    "oauth",
    "devops"
  ],
  "author": {
    "name": "Sky Genesis Enterprise",
    "email": "developer@skygenesisenterprise.com"
  },
  "license": "MIT"
}
